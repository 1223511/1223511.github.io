<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>古建筑管理后台</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, sans-serif;
    }
    body {
      background: #f5f5f5;
      color: #333;
    }
    .admin-header {
      background: #2c3e50;
      color: white;
      padding: 14px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .admin-header h1 {
      font-size: 20px;
      font-weight: 500;
    }
    .admin-logout {
      background: #e74c3c;
      color: white;
      border: none;
      padding: 6px 14px;
      border-radius: 4px;
      cursor: pointer;
    }
    .admin-container {
      display: flex;
      min-height: calc(100vh - 60px);
    }
    .admin-sidebar {
      width: 220px;
      background: white;
      border-right: 1px solid #ddd;
      padding: 20px 0;
    }
    .admin-sidebar ul {
      list-style: none;
    }
    .admin-sidebar li {
      padding: 12px 20px;
      cursor: pointer;
    }
    .admin-sidebar li.active {
      background: #3498db;
      color: white;
    }
    .admin-main {
      flex: 1;
      padding: 24px;
    }
    .admin-page {
      display: none;
    }
    .admin-page.active {
      display: block;
    }
    .card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      padding: 20px;
      margin-bottom: 20px;
    }
    .stat-row {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat-box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.05);
      text-align: center;
    }
    .stat-box h3 {
      font-size: 26px;
      color: #2c3e50;
      margin-bottom: 6px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 8px;
      overflow: hidden;
    }
    th, td {
      padding: 12px 14px;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    th {
      background: #f8f9fa;
    }
    .btn {
      padding: 6px 12px;
      border-radius: 4px;
      border: none;
      cursor: pointer;
      font-size: 14px;
    }
    .btn-primary {
      background: #3498db;
      color: white;
    }
    .btn-danger {
      background: #e74c3c;
      color: white;
    }
    .btn-success{
      background: #28a745;
      color: white;
    }
    .btn-sm {
      padding: 4px 8px;
      font-size: 12px;
    }
    .form-group {
      margin-bottom: 16px;
    }
    label {
      display: block;
      margin-bottom: 6px;
      font-weight: 500;
    }
    input, textarea, select {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
    }
    textarea {
      min-height: 100px;
      resize: vertical;
    }
    .modal {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.5);
      display: flex; align-items: center; justify-content: center;
      z-index: 1000;
      display: none;
    }
    .modal.show {
      display: flex;
    }
    .modal-content {
      background: white;
      width: 90%;
      max-width: 600px;
      border-radius: 8px;
      padding: 24px;
      max-height: 90vh;
      overflow-y: auto;
    }
    .modal-title {
      font-size: 18px;
      margin-bottom: 16px;
    }
    .modal-footer {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 20px;
    }
    img.table-img {
      width: 60px;
      height: 40px;
      object-fit: cover;
      border-radius: 4px;
    }
    .img-preview{
      width: 120px;
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
      margin-top: 8px;
      border: 1px solid #ddd;
    }
    .search-bar {
      margin-bottom: 16px;
      display: flex;
      gap: 10px;
    }
    .search-bar input {
      flex: 1;
    }
    .word-wrap{
      white-space: pre-wrap;
      word-break: break-all;
    }

    /* 登录界面样式 */
    .login-box {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: #2c3e50;
      display: flex; align-items: center; justify-content: center;
      z-index: 9999;
    }
    .login-form {
      background: white;
      padding: 30px;
      border-radius: 10px;
      width: 100%;
      max-width: 380px;
    }
    .login-form h2 {
      margin-bottom: 20px;
      text-align: center;
    }
    .captcha-row {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .captcha-row input {
      flex: 1;
    }
    #captchaCode {
      padding: 8px 12px;
      background: #f0f0f0;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
      user-select: none;
      letter-spacing: 2px;
    }
  </style>
</head>
<body>

<!-- 强制登录：账号 + 密码 + 验证码 -->
<div class="login-box" id="loginBox">
  <div class="login-form">
    <h2>管理员登录</h2>
    <div class="form-group">
      <label>管理员账号</label>
      <input type="text" id="adminUser" placeholder="请输入管理员账号">
    </div>
    <div class="form-group">
      <label>管理员密码</label>
      <input type="password" id="adminPwd" placeholder="请输入密码">
    </div>
    <div class="form-group">
      <label>验证码</label>
      <div class="captcha-row">
        <input type="text" id="captchaInput" placeholder="请输入验证码">
        <div id="captchaCode" onclick="createCaptcha()">ABCD</div>
      </div>
    </div>
    <button class="btn btn-primary" style="width:100%;margin-top:6px;" onclick="adminLogin()">登录</button>
  </div>
</div>

<div class="admin-header">
  <h1>古建筑管理后台</h1>
  <button class="admin-logout" onclick="logout()">退出登录</button>
</div>

<div class="admin-container">
  <div class="admin-sidebar">
    <ul>
      <li class="side-item active" onclick="goAdmin('dashboard')">控制台</li>
      <li class="side-item" onclick="goAdmin('buildManage')">建筑管理</li>
      <li class="side-item" onclick="goAdmin('exhibitNormalManage')">常设展览</li>
      <li class="side-item" onclick="goAdmin('exhibitTempManage')">临时展览</li>
      <li class="side-item" onclick="goAdmin('commentManage')">评论管理</li>
      <li class="side-item" onclick="goAdmin('dataManage')">数据管理</li>
    </ul>
  </div>

  <div class="admin-main">
    <!-- 控制台 -->
    <div id="dashboard" class="admin-page active">
      <div class="stat-row">
        <div class="stat-box">
          <h3 id="totalBuild">0</h3>
          <p>建筑总数</p>
        </div>
        <div class="stat-box">
          <h3 id="totalExhibitNormal">0</h3>
          <p>常设展览</p>
        </div>
        <div class="stat-box">
          <h3 id="totalExhibitTemp">0</h3>
          <p>临时展览</p>
        </div>
        <div class="stat-box">
          <h3 id="totalComment">0</h3>
          <p>评论总数</p>
        </div>
        <div class="stat-box">
          <h3 id="totalDynasty">0</h3>
          <p>朝代数量</p>
        </div>
        <div class="stat-box">
          <h3 id="totalView">0</h3>
          <p>总浏览量</p>
        </div>
        <div class="stat-box">
          <h3 id="totalLike">0</h3>
          <p>总点赞量</p>
        </div>
        <div class="stat-box">
          <h3 id="totalCollect">0</h3>
          <p>总收藏量</p>
        </div>
      </div>

      <div class="card">
        <h3>快捷操作</h3>
        <div style="margin-top:14px; display:flex; gap:10px;">
          <button class="btn btn-primary" onclick="openAddModal()">添加新建筑</button>
          <button class="btn btn-primary" onclick="openAddExhibitNormalModal()">添加常设展览</button>
          <button class="btn btn-primary" onclick="openAddExhibitTempModal()">添加临时展览</button>
          <button class="btn btn-danger" onclick="clearAllData()">清空所有数据</button>
        </div>
      </div>
    </div>

    <!-- 建筑管理 -->
    <div id="buildManage" class="admin-page">
      <div class="search-bar">
        <input type="text" id="buildSearch" placeholder="搜索标题/朝代/类型" oninput="searchBuild()">
        <button class="btn btn-primary" onclick="openAddModal()">+ 新增建筑</button>
      </div>
      <table>
        <thead>
          <tr>
            <th>封面</th>
            <th>标题</th>
            <th>朝代</th>
            <th>类型</th>
            <th>浏览量</th>
            <th>点赞量</th>
            <th>收藏量</th>
            <th>编辑时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="buildTableBody"></tbody>
      </table>
    </div>

    <!-- 常设展览管理 -->
    <div id="exhibitNormalManage" class="admin-page">
      <div class="search-bar">
        <input type="text" id="exhibitNormalSearch" placeholder="搜索展览名称/地点" oninput="searchExhibitNormal()">
        <button class="btn btn-primary" onclick="openAddExhibitNormalModal()">+ 新增常设展览</button>
      </div>
      <table>
        <thead>
          <tr>
            <th>封面</th>
            <th>展览名称</th>
            <th>地点</th>
            <th>时间</th>
            <th>点赞</th>
            <th>收藏</th>
            <th>编辑时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="exhibitNormalTableBody"></tbody>
      </table>
    </div>

    <!-- 临时展览管理 -->
    <div id="exhibitTempManage" class="admin-page">
      <div class="search-bar">
        <input type="text" id="exhibitTempSearch" placeholder="搜索展览名称/地点" oninput="searchExhibitTemp()">
        <button class="btn btn-primary" onclick="openAddExhibitTempModal()">+ 新增临时展览</button>
      </div>
      <table>
        <thead>
          <tr>
            <th>封面</th>
            <th>展览名称</th>
            <th>地点</th>
            <th>时间</th>
            <th>点赞</th>
            <th>收藏</th>
            <th>编辑时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="exhibitTempTableBody"></tbody>
      </table>
    </div>

    <!-- 评论管理 -->
    <div id="commentManage" class="admin-page">
      <table>
        <thead>
          <tr>
            <th>用户</th>
            <th>评论内容</th>
            <th>时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="commentTableBody"></tbody>
      </table>
    </div>

    <!-- 数据管理 -->
    <div id="dataManage" class="admin-page">
      <div class="card">
        <h3>导出/导入数据</h3>
        <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
          <button class="btn btn-primary" onclick="exportData()">导出JSON</button>
          <button class="btn btn-primary" onclick="exportExcel()">导出Excel</button>
          <input type="file" id="importFile" style="display:none;" accept=".json,.xlsx,.xls,.doc,.docx" onchange="importData(event)">
          <button class="btn" onclick="document.getElementById('importFile').click()">导入文件</button>
          <p style="width:100%; margin-top:8px; color:#666;">支持格式：JSON、Excel表格、Word文档</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 建筑弹窗 -->
<div class="modal" id="buildModal">
  <div class="modal-content">
    <div class="modal-title" id="modalTitle">添加建筑</div>
    <input type="hidden" id="editId">
    <div class="form-group"><label>标题</label><input id="formTitle"></div>
    <div class="form-group">
      <label>朝代</label>
      <select id="formDynasty">
        <option value="">请选择朝代</option>
        <option value="唐代">唐代</option>
        <option value="宋代">宋代</option>
        <option value="辽代">辽代</option>
        <option value="金代">金代</option>
        <option value="元代">元代</option>
        <option value="明代">明代</option>
        <option value="清代">清代</option>
      </select>
    </div>
    <div class="form-group">
      <label>类型</label>
      <select id="formType">
        <option value="">请选择类型</option>
        <option value="宫殿">宫殿</option>
        <option value="寺庙">寺庙</option>
        <option value="塔">塔</option>
        <option value="园林">园林</option>
        <option value="楼阁">楼阁</option>
        <option value="民居">民居</option>
        <option value="祠堂">祠堂</option>
      </select>
    </div>
    <div class="form-group">
      <label>图片</label>
      <input type="file" id="formImgFile" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp,image/bmp,image/svg+xml" onchange="previewImg(this)">
      <input type="hidden" id="formImg">
      <img id="imgPreview" class="img-preview" style="display:none;">
    </div>
    <div class="form-group"><label>详细介绍</label><textarea id="formText"></textarea></div>
    <div class="form-group">
      <label>浏览量</label>
      <input type="number" id="formView" value="0" min="0">
    </div>
    <div class="form-group">
      <label>点赞量</label>
      <input type="number" id="formLike" value="0" min="0">
    </div>
    <div class="form-group">
      <label>收藏量</label>
      <input type="number" id="formCollect" value="0" min="0">
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveBuild()">保存</button>
    </div>
  </div>
</div>

<!-- 常设展览弹窗 -->
<div class="modal" id="exhibitNormalModal">
  <div class="modal-content">
    <div class="modal-title" id="exhibitNormalModalTitle">添加常设展览</div>
    <input type="hidden" id="editExhibitNormalId">
    <div class="form-group"><label>展览名称</label><input id="exhibitNormalName"></div>
    <div class="form-group"><label>展览地点</label><input id="exhibitNormalPlace"></div>
    <div class="form-group"><label>展览时间</label><input id="exhibitNormalTime"></div>
    <div class="form-group">
      <label>封面图片</label>
      <input type="file" id="exhibitNormalImgFile" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp,image/bmp,image/svg+xml" onchange="previewExhibitNormalImg(this)">
      <input type="hidden" id="exhibitNormalImg">
      <img id="exhibitNormalPreview" class="img-preview" style="display:none;">
    </div>
    <div class="form-group"><label>展览介绍</label><textarea id="exhibitNormalDesc"></textarea></div>
    <div class="form-group">
      <label>点赞量</label>
      <input type="number" id="exhibitNormalLike" value="0" min="0">
    </div>
    <div class="form-group">
      <label>收藏量</label>
      <input type="number" id="exhibitNormalCollect" value="0" min="0">
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeExhibitNormalModal()">取消</button>
      <button class="btn btn-primary" onclick="saveExhibitNormal()">保存</button>
    </div>
  </div>
</div>

<!-- 临时展览弹窗 -->
<div class="modal" id="exhibitTempModal">
  <div class="modal-content">
    <div class="modal-title" id="exhibitTempModalTitle">添加临时展览</div>
    <input type="hidden" id="editExhibitTempId">
    <div class="form-group"><label>展览名称</label><input id="exhibitTempName"></div>
    <div class="form-group"><label>展览地点</label><input id="exhibitTempPlace"></div>
    <div class="form-group"><label>展览时间</label><input id="exhibitTempTime"></div>
    <div class="form-group">
      <label>封面图片</label>
      <input type="file" id="exhibitTempImgFile" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp,image/bmp,image/svg+xml" onchange="previewExhibitTempImg(this)">
      <input type="hidden" id="exhibitTempImg">
      <img id="exhibitTempPreview" class="img-preview" style="display:none;">
    </div>
    <div class="form-group"><label>展览介绍</label><textarea id="exhibitTempDesc"></textarea></div>
    <div class="form-group">
      <label>点赞量</label>
      <input type="number" id="exhibitTempLike" value="0" min="0">
    </div>
    <div class="form-group">
      <label>收藏量</label>
      <input type="number" id="exhibitTempCollect" value="0" min="0">
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeExhibitTempModal()">取消</button>
      <button class="btn btn-primary" onclick="saveExhibitTemp()">保存</button>
    </div>
  </div>
</div>

<script>
  // ====================== 安全设置 ======================
  const ADMIN_USER = "admin";
  const ADMIN_PASSWORD = "123456";
  let currentCaptcha = "";

  // 固定选项
  const DYNASTY_LIST = ["唐代","宋代","辽代","金代","元代","明代","清代"];
  const TYPE_LIST = ["宫殿","寺庙","塔","园林","楼阁","民居","祠堂"];

  // 获取当前时间 格式化
  function getNowTime(){
    let d = new Date();
    let y = d.getFullYear();
    let m = String(d.getMonth()+1).padStart(2,'0');
    let day = String(d.getDate()).padStart(2,'0');
    let h = String(d.getHours()).padStart(2,'0');
    let mi = String(d.getMinutes()).padStart(2,'0');
    let s = String(d.getSeconds()).padStart(2,'0');
    return `${y}-${m}-${day} ${h}:${mi}:${s}`;
  }

  // ====================== 初始化 ======================
  function initDefaultData() {
      if(!localStorage.getItem("buildData")){
          const defaultBuild = [{}];
          localStorage.setItem("buildData", JSON.stringify(defaultBuild));
      }
      if(!localStorage.getItem("exhibitNormalData")){
          localStorage.setItem("exhibitNormalData", JSON.stringify([]));
      }
      if(!localStorage.getItem("exhibitTempData")){
          localStorage.setItem("exhibitTempData", JSON.stringify([]));
      }
  }

  // 数据方法
  function getData() { let d = localStorage.getItem("buildData"); return d ? JSON.parse(d) : []; }
  function setData(arr) { localStorage.setItem("buildData", JSON.stringify(arr)); }
  
  function getExhibitNormalData() { let d = localStorage.getItem("exhibitNormalData"); return d ? JSON.parse(d) : []; }
  function setExhibitNormalData(arr) { localStorage.setItem("exhibitNormalData", JSON.stringify(arr)); }
  
  function getExhibitTempData() { let d = localStorage.getItem("exhibitTempData"); return d ? JSON.parse(d) : []; }
  function setExhibitTempData(arr) { localStorage.setItem("exhibitTempData", JSON.stringify(arr)); }

  let currentPage = 'dashboard';

  // ====================== 验证码生成 ======================
  function createCaptcha(){
    const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    let code = "";
    for(let i=0;i<4;i++){
      code += chars[Math.floor(Math.random()*chars.length)];
    }
    currentCaptcha = code;
    document.getElementById("captchaCode").innerText = code;
  }

  // ====================== 强制登录：账号+密码+验证码 ======================
  function adminLogin() {
    let user = document.getElementById('adminUser').value.trim();
    let pwd = document.getElementById('adminPwd').value.trim();
    let inputCode = document.getElementById('captchaInput').value.trim().toUpperCase();

    if(!user || !pwd || !inputCode){
      alert('请填写完整信息！');
      return;
    }
    if(inputCode !== currentCaptcha){
      alert('验证码错误！');
      createCaptcha();
      return;
    }
    if(user === ADMIN_USER && pwd === ADMIN_PASSWORD){
      document.getElementById('loginBox').style.display = 'none';
      refresh();
    }else{
      alert('账号或密码错误！');
      createCaptcha();
    }
  }

  // 退出 → 回到登录页
  function logout() {
    location.reload();
  }

  // ====================== 页面切换 ======================
  function goAdmin(id) {
    currentPage = id;
    document.querySelectorAll('.admin-page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.side-item').forEach(i => i.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    if(event) event.target.classList.add('active');
    refresh();
  }

  function refresh() {
    if (currentPage === 'dashboard') loadDashboard();
    if (currentPage === 'buildManage') renderBuildTable();
    if (currentPage === 'exhibitNormalManage') renderExhibitNormalTable();
    if (currentPage === 'exhibitTempManage') renderExhibitTempTable();
    if (currentPage === 'commentManage') renderCommentTable();
  }

  // 控制台
  function loadDashboard() {
    let buildData = getData();
    let normalData = getExhibitNormalData();
    let tempData = getExhibitTempData();
    
    document.getElementById('totalBuild').innerText = buildData.length - 1;
    document.getElementById('totalExhibitNormal').innerText = normalData.length;
    document.getElementById('totalExhibitTemp').innerText = tempData.length;
    
    // 统计总浏览/点赞/收藏
    let totalView = 0, totalLike = 0, totalCollect = 0;
    buildData.forEach((b,i)=>{ if(i!==0){ totalView += b.view||0; totalLike += b.like||0; totalCollect += b.collect||0; } });
    normalData.forEach(e=>{ totalLike += e.like||0; totalCollect += e.collect||0; });
    tempData.forEach(e=>{ totalLike += e.like||0; totalCollect += e.collect||0; });
    
