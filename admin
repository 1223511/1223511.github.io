  // ====================== 数据管理 ======================
  function exportExcel(){
    let data = getData().filter((_,i)=>i!==0);
    let csv = "标题,朝代,类型,浏览量,点赞量,收藏量,介绍,编辑时间\n";
    data.forEach(item=>{
      csv += `${item.title},${item.dynasty},${item.type},${item.view||0},${item.like||0},${item.collect||0},"${item.text||''}",${item.editTime||''}\n`;
    });
    let blob = new Blob([new Uint8Array([0xEF,0xBB,0xBF]), csv], {type: 'text/csv;charset=utf-8'});
    let a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = "古建筑数据.csv";
    a.click();
  }
  function importData(e) {
    let file = e.target.files[0];
    if (!file) return;
    let reader = new FileReader();
    reader.onload = ev => {
      try {
        let text = ev.target.result;
        if(file.name.endsWith('.json')){
          let data = JSON.parse(text);
          if (data.buildData) setData(data.buildData);
          if (data.exhibitNormalData) setExhibitNormalData(data.exhibitNormalData);
          if (data.exhibitTempData) setExhibitTempData(data.exhibitTempData);
          if (data.comments) localStorage.setItem('comments', JSON.stringify(data.comments));
        }else{
          let lines = text.split(/\n|\r/).filter(l=>l.trim());
          let build = getData();
          lines.forEach(line=>{
            let arr = line.split(/[,，\t]/).map(v=>v.trim().replace(/"/g,''));
            if(arr.length>=3){
              build.push({
                title:arr[0]||'无标题',
                dynasty:arr[1]||'清代',
                type:arr[2]||'宫殿',
                img:'https://picsum.photos/800/600?random='+Math.random(),
                text:arr[3]||'',
                view:0, like:0, collect:0,
                editTime:getNowTime()
              });
            }
          });
          setData(build);
        }
        alert('导入成功'); refresh();
      } catch(e) { 
        alert('解析失败：'+e.message);
      }
    };
    reader.readAsText(file);
  }
  function exportData() {
    let all = {
      buildData: getData(),
      exhibitNormalData: getExhibitNormalData(),
      exhibitTempData: getExhibitTempData(),
      comments: JSON.parse(localStorage.getItem('comments') || '[]')
    };
    let blob = new Blob([JSON.stringify(all, null, 2)], { type: 'application/json' });
    let a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = '古建筑数据.json';
    a.click();
  }
